{
  "dataset_name": "tep",
  "protocol_name": "tep_multimode_mode_holdout_v2",
  "split_protocol": "tep_multimode_mode_holdout_v2",
  "description": "Multimode TEP protocol: normal training uses M1-M4 d00, validation uses M5 d00, normal test uses M6 d00, fault evaluation uses all d01-d28 across all modes.",
  "dataset_fields": {
    "mode_field": "mode",
    "run_id_field": "run_id",
    "fault_field": "fault_id",
    "scenario_field": "scenario_id",
    "timestamp_field": "timestamp",
    "window_index_field": "window_idx",
    "run_key_field": "run_key"
  },
  "modes": {
    "train_modes": ["M1", "M2", "M3", "M4"],
    "val_modes": ["M5"],
    "test_normal_modes": ["M6"],
    "fault_eval_modes": ["M1", "M2", "M3", "M4", "M5", "M6"]
  },
  "run_sets": {
    "train_normal_run_keys": ["M1_d00", "M2_d00", "M3_d00", "M4_d00"],
    "val_normal_run_keys": ["M5_d00"],
    "normal_test_run_keys": ["M6_d00"],
    "fault_eval_scenarios": [
      "d01", "d02", "d03", "d04", "d05", "d06", "d07", "d08", "d09", "d10",
      "d11", "d12", "d13", "d14", "d15", "d16", "d17", "d18", "d19", "d20",
      "d21", "d22", "d23", "d24", "d25", "d26", "d27", "d28"
    ],
    "fault_eval_rule": "all fault runs across all modes"
  },
  "windowing": {
    "window_length": 128,
    "horizon": 1,
    "window_within_run_only": true,
    "cross_run_windows": false
  }
}
